{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["worker", "employer", "admin", "super_admin"] },
        "region": { "type": "string" },
        "district": { "type": "string" },
        "neighborhood": { "type": "string" },
        "bio": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "experienceLevel": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "completedJobs": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "verificationStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"] },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "role", "region"]
    },
    "ServicePost": {
      "title": "Worker Service Listing",
      "description": "A service offer posted by a worker.",
      "type": "object",
      "properties": {
        "workerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "expectedPrice": { "type": "number" },
        "region": { "type": "string" },
        "district": { "type": "string" },
        "neighborhood": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "hidden", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workerId", "title", "category", "region", "status"]
    },
    "Job": {
      "title": "Job Listing",
      "description": "A job posted by an employer.",
      "type": "object",
      "properties": {
        "employerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "workType": { "type": "string", "enum": ["one-time", "recurring", "full-time"] },
        "region": { "type": "string" },
        "district": { "type": "string" },
        "neighborhood": { "type": "string" },
        "address": { "type": "string" },
        "deadline": { "type": "string", "format": "date" },
        "images": { "type": "array", "items": { "type": "string" } },
        "requirements": { "type": "string" },
        "contractConditions": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "filled", "in-progress", "completed", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["employerId", "title", "category", "price", "region"]
    },
    "Application": {
      "title": "Job Application",
      "description": "A worker's application for a job.",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "workerId": { "type": "string" },
        "employerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "shortlisted", "accepted", "rejected"] },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jobId", "workerId", "employerId", "status"]
    },
    "Contract": {
      "title": "Employment Contract",
      "description": "A legal agreement between employer and worker.",
      "type": "object",
      "properties": {
        "jobId": { "type": "string" },
        "workerId": { "type": "string" },
        "employerId": { "type": "string" },
        "amount": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "terms": { "type": "string" },
        "employerSigned": { "type": "boolean" },
        "workerSigned": { "type": "boolean" },
        "adminApproved": { "type": "boolean" },
        "status": { "type": "string", "enum": ["draft", "signed", "active", "completed", "disputed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jobId", "workerId", "employerId", "amount", "status"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message sent between users.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "attachmentUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "receiverId", "text"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "link": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read"]
    },
    "Dispute": {
      "title": "Contract Dispute",
      "description": "A dispute opened on a contract.",
      "type": "object",
      "properties": {
        "contractId": { "type": "string" },
        "openedById": { "type": "string" },
        "reason": { "type": "string" },
        "evidenceUrls": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "investigating", "resolved", "rejected"] },
        "adminDecision": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["contractId", "openedById", "reason", "status"]
    },
    "VerificationRequest": {
      "title": "Verification Request",
      "description": "Request for identity verification.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "idPhotoUrl": { "type": "string" },
        "selfieUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "idPhotoUrl", "selfieUrl", "status"]
    }
  },
  "firestore": {
    "/profiles/{uid}": { "schema": "Profile", "description": "User profiles." },
    "/jobs/{jobId}": { "schema": "Job", "description": "Job listings." },
    "/service_posts/{postId}": { "schema": "ServicePost", "description": "Worker service listings." },
    "/applications/{applicationId}": { "schema": "Application", "description": "Job applications." },
    "/contracts/{contractId}": { "schema": "Contract", "description": "Employment contracts." },
    "/chat_messages/{messageId}": { "schema": "ChatMessage", "description": "Chat messages." },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications." },
    "/disputes/{disputeId}": { "schema": "Dispute", "description": "Contract disputes." },
    "/verification_requests/{requestId}": { "schema": "VerificationRequest", "description": "Verification requests." }
  }
}
